            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::914242301484:oidc-provider/oidc.eks.ap-south-1.amazonaws.com/id/58BFA10EA3A40C9B4EAA481E863C9AAE\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.ap-south-1.amazonaws.com/id/58BFA10EA3A40C9B4EAA481E863C9AAE:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.ap-south-1.amazonaws.com/id/58BFA10EA3A40C9B4EAA481E863C9AAE:sub\": \"system:serviceaccount:kube-system:ebs-csi-controller-sa\"\n        }\n      }\n    }\n  ]\n}",
